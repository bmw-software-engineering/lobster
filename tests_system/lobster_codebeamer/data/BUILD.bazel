load("@rules_python//python:defs.bzl", "py_library")
load("//bazel/private:generate_certs.bzl", "generate_certs")

# Bazel equivalent of: make codebeamer-pem
# Generates self-signed SSL certificates for codebeamer system tests
generate_certs(
    name = "codebeamer_pem",
)

filegroup(
    name = "codebeamer_data_system",
    srcs = glob(["*.lobster"]) + [":codebeamer_pem"],
    visibility = ["//visibility:public"],
)

py_library(
    name = "data",
    srcs = ["generate_mock_data.py"],
    visibility = ["//:__subpackages__"],
)
